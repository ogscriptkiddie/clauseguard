{
  "manifest_version": 3,
  "name": "ClauseGuard",
  "version": "2.0.0",
  "description": "Automatically detects privacy & security risks in Terms of Service. Alerts you before you sign up.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ClauseGuard — Analyze this page"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "host_permissions": [
    "http://localhost:5000/*"
  ]
}
